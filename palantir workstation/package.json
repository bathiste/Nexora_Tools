{
  "name": "pentest-beam",
  "version": "1.0.0",
  "description": "Authorized penetration testing platform with proxy rotation and user agent support",
  "main": "main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "api": "node dist/api.js",
    "api:dev": "ts-node src/api.ts",
    "dashboard": "python -m http.server 8080 --directory dashboard --bind 127.0.0.1",
    "start:all": "concurrently \"npm run api:dev\" \"npm run dashboard\"",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dashboard\" \"electron . --dev\""
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "axios": "^1.6.0",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "electron": "^28.0.0",
    "express": "^4.18.2",
    "http-proxy-agent": "^7.0.0",
    "https-proxy-agent": "^7.0.2",
    "nodemailer": "^6.10.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "socks-proxy-agent": "^8.0.2",
    "speakeasy": "^2.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "pentest",
    "security",
    "proxy",
    "load-testing"
  ],
  "author": "bathist",
  "license": "MIT"
}
